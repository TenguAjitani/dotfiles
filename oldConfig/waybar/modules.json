{
	"hyprland/workspaces": {
		"all-outputs": true,
		"format": "{name}",
		"on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
		"on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
	},
	
	"mpris": {
		"format": "{player_icon} <span color='#ce5987'>{dynamic}</span>",
		"format-paused": "{status_icon} <span color='#ce5987'><i>{dynamic}</i></span>",
		"dynamic-order": ["title", "artist", "album"],
		"title-len": 30,
		"artist-len": 30,
		"album-len": 15,
		"dynamic-separator": "<b>/</b>",
		"player-icons": {
			"default": "ÔľÂ",
			"mpv": "´Çü"
		},
		"status-icons": {
			"paused": "ÔĆŞ"
		},
		// "ignored-players": ["firefox"]
	},
	
	"clock": {
		"format": "<span color='#ee5396'>´ü│</span> {:%A %e %B}",
		"tooltip": false
	},
	
	"custom/lock":{
		"format": "´Çú",
		"on-click": "systemctl sleep",
		"tooltip": false
	},
	
	"custom/notification":{
		"format": "ˇ▒ůź",
		"on-click": "swaync-client -t -sw",
		"tooltip": false
	},
		

	"network": {
        	// "interface": "wlp2s0", // (Optional) To force the use of this interface
        	"format-wifi": "<span color='#94d1ef'>´çź</span>  {essid}  ",
        	"format-ethernet": "<span color='#e7fcfe'>´Çĺ</span>  {ifname}",
        	"format-linked": "<span color='#e7fcfe'>´Çĺ</span>  {ifname} (No IP)",
		"format": "<span color='#e7fcfe'>´Çĺ</span>  Connected",
        	"format-disconnected": "<span color='#e7fcfe'>´Üö</span>  Disconnected",
	        "interval": 60
	},

	"memory": {
		"interval": 5,
		"format": "´őŤ {}%"
	},

	"cpu": {
		"interval": 5,
		"format": "´äł {usage}%"
	},
	
	"wireplumber": {
		"on-click": "pavucontrol",
		"on-click-right": "amixer sset Master toggle 1>/dev/null",
		"format": "<span foreground='#a2809e'>{icon}</span> {volume}%",
		"format-muted": "<span foreground='#a2809e'>´Üę</span> Muted",
		"format-icons": {
		    "headphone": "´Çą ",
		    "hands-free": "´ľÉ ",
		    "headset": "´ľÉ ",
		    "phone": "´éĽ ",
		    "portable": "´éĽ ",
		    "car": "´ć╣ ",
		    "default": ["´ÇŽ ", "´Çž ", "´ÇĘ "]
		},
	},

	"tray": {
		"icon-size": 15
	},

	"clock#time": {
		"format": "<span color='#e57474'>´ÇŚ</span> {:%H:%M}",
		"tooltip": false
	},
		
	"battery": {
		"interval": 2,
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format": "<span color='#f7d0df'>{icon}</span> {capacity}%",
		"format-charging": "<span color='#8ccf7e'>´çŽ</span> {capacity}%",
		"format-plugged": "<span color='#8ccf7e'>´çŽ</span> {capacity}%",
		"format-icons": [
			"´ëä",
